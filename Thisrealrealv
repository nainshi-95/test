# 5. 테스트 코드 (변경 없음)
# ----------------------------------------------------------------------------
if __name__ == "__main__":
    
    def run_test(test_name, test_symbols, pmf, offsets, indexes):
        print(f"\n--- {test_name} ---")
        print(f"원본 심볼: {test_symbols} (총 {len(test_symbols)}개)")

        precision = 16 
        
        my_cdf = pmf_to_quantized_cdf(pmf, precision)
        
        cdfs = [my_cdf]
        cdfs_sizes = [len(my_cdf)]

        # --- 인코딩 ---
        encoder = RansEncoderLibByte(precision=precision) 
        encoder.encode_with_indexes(test_symbols, indexes, cdfs, cdfs_sizes, offsets)
        encoder.flush()
        encoded_stream = encoder.get_encoded_stream()
        
        stream_len = len(encoded_stream)
        bpp = (stream_len * 8 / len(test_symbols)) if test_symbols else 0
        
        print(f"스트림 크기: {stream_len} 바이트")
        print(f"BPP (per symbol): {bpp:.4f}")

        # --- 디코딩 ---
        decoder = RansDecoderLibByte(precision=precision)
        decoder.set_stream(encoded_stream)
        decoded_symbols = decoder.decode_stream(indexes, cdfs, cdfs_sizes, offsets)
        print(f"디코딩된 심볼: {decoded_symbols}")

        # --- 검증 ---
        assert test_symbols == decoded_symbols
        print(f"✅ {test_name} 통과!")


    # --- 테스트 1: (다중 심볼 및 바이패스) ---
    pmf_1 = [0.2, 0.5, 0.3] 
    symbols_1 = [0, 1, 2, 1, 0, 3, 1, 2, -1, 0, -10, 10, 1]
    offsets_1 = [0]
    indexes_1 = [0] * len(symbols_1)
    run_test("다중 심볼 (Byte)", symbols_1, pmf_1, offsets_1, indexes_1)
    
    # --- 테스트 2: (단일 심볼) ---
    pmf_2 = [0.8, 0.2]
    symbols_2 = [0]
    offsets_2 = [0]
    indexes_2 = [0] * len(symbols_2)
    run_test("단일 심볼 (Byte)", symbols_2, pmf_2, offsets_2, indexes_2)
    
    # --- 테스트 3: (Offset 테스트) ---
    pmf_3 = [0.1, 0.9] # 0, 1
    symbols_3 = [100, 101, 100, 100] # offset 100 기준 0, 1, 0, 0
    offsets_3 = [100]
    indexes_3 = [0] * len(symbols_3)
    run_test("Offset 테스트 (Byte)", symbols_3, pmf_3, offsets_3, indexes_3)
