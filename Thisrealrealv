# ----------------------------------------------------------------------------
# 1. pmf_to_quantized_cdf (변경 없음)
# ----------------------------------------------------------------------------
def pmf_to_quantized_cdf(pmf: List[float], precision: int) -> List[int]:
    # ... (이전과 동일) ...
    cdf = [0] * (len(pmf) + 1)
    scale = 1 << precision
    for i, p in enumerate(pmf):
        scaled_p = p * scale
        cdf[i + 1] = int(math.floor(scaled_p + 0.5))
    total = sum(cdf)
    if total == 0: total = 1
    for i in range(len(cdf)):
        cdf[i] = (scale * cdf[i]) // total
    current_sum = 0
    for i in range(len(cdf)):
        current_sum += cdf[i]
        cdf[i] = current_sum
    cdf[-1] = scale
    n = len(cdf) - 1
    for i in range(n):
        if cdf[i] == cdf[i + 1]:
            best_freq = (1 << 32) - 1
            best_steal = -1
            for j in range(n):
                freq = cdf[j + 1] - cdf[j]
                if freq > 1 and freq < best_freq:
                    best_freq = freq
                    best_steal = j
            assert best_steal != -1
            if best_steal < i:
                for j in range(best_steal + 1, i + 1): cdf[j] -= 1
            else:
                assert best_steal > i
                for j in range(i + 1, best_steal + 1): cdf[j] += 1
    assert cdf[0] == 0
    assert cdf[-1] == scale
    for i in range(n):
        assert cdf[i + 1] > cdf[i]
    return cdf

# ----------------------------------------------------------------------------
# 2. RansSymbol (변경 없음)
# ----------------------------------------------------------------------------
@dataclass
class RansSymbol:
    start: int
    range: int
    bypass: bool

# ----------------------------------------------------------------------------
# 3. 바이트 헬퍼 (Encoder는 지난번 수정, Decoder가 이번 수정)
# ----------------------------------------------------------------------------

class RansByteEncoder:
    """(지난번 수정된 버전) 1바이트 단위 인코더 헬퍼"""
    def __init__(self, precision):
        self.precision = precision
        self.scale = 1 << precision
        self.L_BASE = (1 << 16)
        self.TOP = (1 << 24)
        self.state = self.L_BASE
        self.stream = bytearray()

    def encode(self, start, freq):
        x = self.state
        x_max = (self.TOP >> self.precision) * freq # (지난번 수정된 부분)
        while x >= x_max:
            self.stream.append(x & 0xFF)
            x >>= 8
        self.state = ((x // freq) * self.scale) + (x % freq) + start

    def flush(self) -> bytes:
        x = self.state
        # 4바이트 flush (LIFO 순서로 추가)
        self.stream.append((x >> 0) & 0xFF)
        self.stream.append((x >> 8) & 0xFF)
        self.stream.append((x >> 16) & 0xFF)
        self.stream.append((x >> 24) & 0xFF)
        # 전체를 뒤집어 FIFO 스트림 반환
        return bytes(reversed(self.stream))


class RansByteDecoder:
    """[수정됨] 1바이트 단위 디코더 헬퍼 (pop() -> ptr)"""
    def __init__(self, precision, stream: bytes):
        self.precision = precision
        self.scale = 1 << precision
        self.L_BASE = (1 << 16)
        
        # [수정] 스트림을 바이트 객체로 저장
        self.stream: bytes = stream 
        self.ptr: int = 0 # [수정] 포인터(인덱스) 사용
        
        # [수정] 스트림의 맨 앞 4바이트(FIFO)를 읽어 상태 초기화
        # 인코더가 [B0, B1, B2, B3] (LIFO) -> [B3, B2, B1, B0] (FIFO)로 썼음
        b0 = self.stream[3]
        b1 = self.stream[2]
        b2 = self.stream[1]
        b3 = self.stream[0]
        
        self.state = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
        self.ptr = 4 # 데이터(Renorm)는 인덱스 4부터 시작

    def get_symbol(self) -> int:
        """현재 상태에서 누적 빈도를 읽습니다."""
        return self.state & (self.scale - 1)

    def decode(self, start, freq):
        """심볼(start, freq)을 기반으로 디코더 상태를 업데이트합니다."""
        self.state = freq * (self.state >> self.precision) + (self.state & (self.scale - 1)) - start
        
        # [수정] pop() 대신 ptr로 스트림에서 읽기
        while self.state < self.L_BASE:
            self.state = (self.state << 8) | self.stream[self.ptr]
            self.ptr += 1

