# 이전 답변에서 제공된 get_jpeg_ecs_size 함수를 여기에 포함합니다.
def get_jpeg_ecs_size(filepath):
    """
    JPEG 파일의 순수 데이터(Entropy-Coded Segment) 크기를 반환합니다.

    Args:
        filepath (str): JPEG 파일 경로

    Returns:
        int: ECS 데이터의 크기 (바이트)
        None: JPEG 마커를 찾지 못한 경우
    """
    SOS_MARKER = b'\xFF\xDA'  # Start of Scan
    EOI_MARKER = b'\xFF\xD9'  # End of Image

    try:
        with open(filepath, 'rb') as f:
            data = f.read()

        eoi_pos = data.rfind(EOI_MARKER) 
        if eoi_pos == -1:
            # print(f"오류: EOI (FF D9) 마커를 찾을 수 없습니다. (파일: {filepath})")
            return None

        sos_pos = data.rfind(SOS_MARKER, 0, eoi_pos)
        
        if sos_pos == -1:
            # print(f"오류: SOS (FF DA) 마커를 찾을 수 없습니다. (파일: {filepath})")
            return None

        scan_header_len = int.from_bytes(data[sos_pos+2 : sos_pos+4], 'big')
        ecs_start = sos_pos + 2 + scan_header_len
        ecs_size = eoi_pos - ecs_start
        
        return ecs_size

    except FileNotFoundError:
        # print(f"오류: 파일을 찾을 수 없습니다. (파일: {filepath})")
        return None
    except Exception as e:
        # print(f"파일 처리 중 오류 발생: {e}")
        return None

