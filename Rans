import bisect

class RansEncoderDecoder:
    """
    rANS(range Asymmetric Numeral Systems)를 사용하여
    심볼 시퀀스를 인코딩 및 디코딩하는 클래스. (Flush/Set_Bitstream 기능 포함)
    """

    def __init__(self, precision_bits=20):
        if not 16 <= precision_bits <= 30:
            print(f"Warning: {precision_bits}bit 정밀도는 비효율적이거나 "
                  "Python 정수 한계를 벗어날 수 있습니다. (권장: 20-30)")

        self.precision_bits = precision_bits
        self.M = 1 << self.precision_bits  # 확률의 총합 (분모)

        self.CHUNK_BITS = 32
        self.LOWER_BOUND = 1 << self.CHUNK_BITS

        # 64비트(청크 2개)로 상태를 저장한다고 가정합니다.
        self.STATE_CHUNKS = 2

        # 내부 상태 변수
        self.encode_state = self.M
        self.encode_bitstream = []
        
        self.decode_state = 0
        self.decode_bitstream = []

    def encode(self, cmf_tables, indices):
        """
        심볼 인덱스 리스트를 인코딩하여 내부 상태를 업데이트합니다.
        rANS는 LIFO(Last-In, First-Out) 방식으로, 리스트의 *역순*으로 인코딩합니다.

        Args:
            cmf_tables (list[list[int]]): 각 심볼에 해당하는 CMF 테이블의 리스트.
            indices (list[int]): 인코딩할 심볼의 인덱스 리스트.
        """
        
        if len(cmf_tables) != len(indices):
            raise ValueError("CMF 테이블 리스트와 인덱스 리스트의 길이가 다릅니다.")

        # LIFO: 리스트의 역순으로 인코딩
        for cmf, index in reversed(list(zip(cmf_tables, indices))):
            if not (0 <= index < len(cmf) - 1):
                raise ValueError(f"인덱스 {index}가 CMF 테이블(길이: {len(cmf)}) 범위를 벗어났습니다.")
            
            c = cmf[index]
            f = cmf[index+1] - c  # f = 빈도수(frequency)

            if f == 0:
                raise ValueError(f"인덱스 {index}의 빈도수(f)가 0입니다. CMF 테이블 오류.")
            if cmf[-1] != self.M:
                raise ValueError(f"CMF 테이블이 정규화되지 않았습니다. "
                                 f"cmf[-1] ({cmf[-1]}) != M ({self.M})")

            # 1. 정규화 (Renormalization)
            while self.encode_state >= (f << self.CHUNK_BITS):
                self.encode_bitstream.append(self.encode_state & ((1 << self.CHUNK_BITS) - 1))
                self.encode_state >>= self.CHUNK_BITS

            # 2. 인코딩 (상태 업데이트)
            self.encode_state = (self.encode_state // f) * self.M + (self.encode_state % f) + c

    def flush(self):
        """
        인코딩을 완료하고, 최종 상태를 포함한 전체 비트스트림을 반환합니다.
        인코더의 상태는 초기화됩니다.

        Returns:
            list[int]: 최종 비트스트림 (32비트 청크 리스트).
        """
        
        # 현재 비트스트림을 복사
        final_stream = list(self.encode_bitstream)
        
        state = self.encode_state
        
        # LIFO: 최종 상태(state)를 비트스트림의 *끝*에 추가합니다.
        # 디코더가 pop()으로 가장 먼저 읽을 데이터입니다.
        # 여기서는 64비트(청크 2개)로 상태를 저장합니다.
        for _ in range(self.STATE_CHUNKS):
            final_stream.append(state & ((1 << self.CHUNK_BITS) - 1))
            state >>= self.CHUNK_BITS

        if state != 0:
             print(f"Warning: 인코더 상태가 {self.STATE_CHUNKS}개 청크(64비트)를 초과했습니다.")

        # 인코더 상태 리셋
        self.encode_state = self.M
        self.encode_bitstream = []

        return final_stream

    def set_bitstream(self, bitstream_chunks):
        """
        디코딩을 위해 비트스트림을 설정합니다.
        비트스트림에서 초기 상태(state)를 읽어오고, 나머지를 저장합니다.

        Args:
            bitstream_chunks (list[int]): flush()에서 반환된 전체 비트스트림.
        """
        if not bitstream_chunks or len(bitstream_chunks) < self.STATE_CHUNKS:
            raise ValueError("비트스트림이 비어있거나 상태(state) 정보를 읽기에 너무 짧습니다.")
            
        self.decode_bitstream = list(bitstream_chunks)
        
        # LIFO: 비트스트림의 *끝*에서 상태(state)를 읽어옵니다. (flush()와 대칭)
        state = 0
        for i in range(self.STATE_CHUNKS):
            chunk = self.decode_bitstream.pop()
            state |= (chunk << (self.CHUNK_BITS * i))
            
        self.decode_state = state

    def decode(self, cmf_tables):
        """
        설정된 비트스트림과 CMF 테이블을 사용하여 심볼 인덱스 리스트를 복원합니다.
        rANS는 FIFO(First-In, First-Out) 방식으로, CMF 테이블의 *정순*으로 디코딩합니다.

        Args:
            cmf_tables (list[list[int]]): 인코딩에 사용된 CMF 테이블 리스트 (정순).

        Returns:
            list[int]: 디코딩된 심볼 인덱스 리스트.
        """
        
        state = self.decode_state
        chunks = self.decode_bitstream
        decoded_indices = []

        # FIFO: CMF 테이블 리스트의 정순으로 디코딩
        for cmf in cmf_tables:
            if cmf[-1] != self.M:
                raise ValueError(f"CMF 테이블이 정규화되지 않았습니다. "
                                 f"cmf[-1] ({cmf[-1]}) != M ({self.M})")
                                 
            # 1. 심볼 찾기 (state % M)
            slot = state & (self.M - 1)

            # 이진 탐색으로 'index'를 찾음: cmf[index] <= slot < cmf[index+1]
            index = bisect.bisect_right(cmf, slot) - 1

            if not (0 <= index < len(cmf) - 1):
                raise ValueError(f"디코딩 실패: slot {slot}이 CMF 범위에 없습니다.")

            decoded_indices.append(index)

            c = cmf[index]
            f = cmf[index+1] - c  # f = 빈도수(frequency)

            # 2. 디코딩 (상태 업데이트)
            state = f * (state >> self.precision_bits) + slot - c

            # 3. 정규화 (Renormalization)
            while state < self.LOWER_BOUND and chunks:
                bits = chunks.pop()
                state = (state << self.CHUNK_BITS) | bits
        
        # 나중을 위해 최종 상태 저장 (필수는 아님)
        self.decode_state = state
        self.decode_bitstream = chunks

        return decoded_indices






if __name__ == "__main__":
    # 1. 설정
    PRECISION = 10
    M = 1 << PRECISION  # M = 1024

    # 2. 인코딩할 데이터 준비
    cmf_0 = [0, 307, 614, 1024]
    cmf_1 = [0, 512, 1024]
    cmf_2 = [0, 102, 307, 922, 1024]

    all_cmf_tables = [cmf_0, cmf_1, cmf_2, cmf_0]
    symbol_indices = [1,      0,     3,     2]

    print(f"Original Indices: {symbol_indices}")
    print("-" * 30)

    # 3. 인코딩
    encoder = RansEncoderDecoder(precision_bits=PRECISION)
    try:
        # 심볼 인코딩 (내부 상태에 저장됨)
        encoder.encode(all_cmf_tables, symbol_indices)
        
        # 인코딩 완료 후 flush() 호출
        bitstream = encoder.flush()
        
        print(f"Encoding successful.")
        print(f"Total Bitstream Chunks: {len(bitstream)}")
        # print(f"Bitstream (state included): {bitstream}")
        print("-" * 30)

        # 4. 디코딩
        #    (새 인스턴스를 사용하거나, 동일 인스턴스를 사용해도 됩니다)
        decoder = RansEncoderDecoder(precision_bits=PRECISION)
        
        # (필수) 디코딩 전 set_bitstream() 호출
        decoder.set_bitstream(bitstream)
        
        # CMF 테이블을 순서대로 전달하여 디코딩
        decoded_indices = decoder.decode(all_cmf_tables)

        print(f"Decoding successful.")
        print(f"Decoded Indices:  {decoded_indices}")

        # 5. 검증
        assert symbol_indices == decoded_indices
        print("\nVerification: SUCCESS! (Original == Decoded)")

    except ValueError as e:
        print(f"\nError: {e}")




