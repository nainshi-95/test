import bisect
import struct  # 32비트 정수 <-> bytes 변환을 위해 추가

class RansEncoderDecoder:
    """
    rANS(range Asymmetric Numeral Systems)를 사용하여
    심볼 시퀀스를 인코딩 및 디코딩하는 클래스. (바이너리 파일 I/O 지원)
    """

    def __init__(self, precision_bits=20):
        if not 16 <= precision_bits <= 30:
            print(f"Warning: {precision_bits}bit 정밀도는 비효율적이거나 "
                  "Python 정수 한계를 벗어날 수 있습니다. (권장: 20-30)")

        self.precision_bits = precision_bits
        self.M = 1 << self.precision_bits  # 확률의 총합 (분모)

        self.CHUNK_BITS = 32
        self.CHUNK_BYTES = self.CHUNK_BITS // 8  # 4 바이트
        self.LOWER_BOUND = 1 << self.CHUNK_BITS

        # 64비트(청크 2개)로 상태를 저장
        self.STATE_CHUNKS = 2

        # 내부 상태 변수
        self.encode_state = self.M
        self.encode_bitstream = []  # list[int]
        
        self.decode_state = 0
        self.decode_bitstream = []  # list[int]

    def encode(self, cmf_tables, indices):
        """ (이전과 동일) """
        
        if len(cmf_tables) != len(indices):
            raise ValueError("CMF 테이블 리스트와 인덱스 리스트의 길이가 다릅니다.")

        # LIFO: 리스트의 역순으로 인코딩
        for cmf, index in reversed(list(zip(cmf_tables, indices))):
            if not (0 <= index < len(cmf) - 1):
                raise ValueError(f"인덱스 {index}가 CMF 테이블(길이: {len(cmf)}) 범위를 벗어났습니다.")
            
            c = cmf[index]
            f = cmf[index+1] - c  # f = 빈도수(frequency)

            if f == 0:
                raise ValueError(f"인덱스 {index}의 빈도수(f)가 0입니다. CMF 테이블 오류.")
            if cmf[-1] != self.M:
                raise ValueError(f"CMF 테이블이 정규화되지 않았습니다. "
                                 f"cmf[-1] ({cmf[-1]}) != M ({self.M})")

            # 1. 정규화 (Renormalization)
            while self.encode_state >= (f << self.CHUNK_BITS):
                self.encode_bitstream.append(self.encode_state & ((1 << self.CHUNK_BITS) - 1))
                self.encode_state >>= self.CHUNK_BITS

            # 2. 인코딩 (상태 업데이트)
            self.encode_state = (self.encode_state // f) * self.M + (self.encode_state % f) + c

    def flush(self) -> bytes:
        """ (이전과 동일) """
        
        # 32비트 정수 청크 리스트를 생성
        final_stream_chunks = list(self.encode_bitstream)
        
        state = self.encode_state
        
        # LIFO: 최종 상태(state)를 64비트(청크 2개)로 리스트 *끝*에 추가
        # [..., state_low, state_high] 순서로 저장됨
        for _ in range(self.STATE_CHUNKS):
            final_stream_chunks.append(state & ((1 << self.CHUNK_BITS) - 1))
            state >>= self.CHUNK_BITS

        if state != 0:
             print(f"Warning: 인코더 상태가 {self.STATE_CHUNKS}개 청크(64비트)를 초과했습니다.")

        # [수정] list[int] -> bytes 변환
        try:
            # '<' : 리틀 엔디안
            # 'I' : 32비트 부호 없는 정수 (unsigned int)
            num_chunks = len(final_stream_chunks)
            packed_bytes = struct.pack(f'<{num_chunks}I', *final_stream_chunks)
        except struct.error as e:
            raise IOError(f"비트스트림 패킹 실패: {e}")

        # 인코더 상태 리셋
        self.encode_state = self.M
        self.encode_bitstream = []

        return packed_bytes

    def set_bitstream(self, bitstream_bytes: bytes):
        """
        디코딩을 위해 'bytes' 비트스트림을 설정합니다. (버그 수정됨)
        """
        if not bitstream_bytes or len(bitstream_bytes) % self.CHUNK_BYTES != 0:
            raise ValueError(f"비트스트림 크기가 {self.CHUNK_BYTES}바이트 배수가 아닙니다 (데이터 손상 가능성).")

        num_chunks = len(bitstream_bytes) // self.CHUNK_BYTES
        
        if num_chunks < self.STATE_CHUNKS:
             raise ValueError("비트스트림이 상태(state) 정보를 읽기에 너무 짧습니다.")
            
        try:
            unpacked_tuple = struct.unpack(f'<{num_chunks}I', bitstream_bytes)
            self.decode_bitstream = list(unpacked_tuple) 
        except struct.error as e:
            raise IOError(f"비트스트림 언패킹 실패: {e}")

        # --- [버그 수정 지점] ---
        # LIFO: 비트스트림의 *끝*에서 상태(state)를 읽어옵니다.
        # flush가 [..., state_low, state_high]로 썼으므로,
        # pop()은 state_high, state_low 순서로 나옵니다.
        state = 0
        
        # state = (state_high << 32) | (state_low << 0) 가 되어야 합니다.
        
        # i=0일 때 pop() -> state_high
        # i=1일 때 pop() -> state_low
        for i in range(self.STATE_CHUNKS):
            chunk = self.decode_bitstream.pop() 
            # i=0일 때 state_high -> 32비트 시프트
            # i=1일 때 state_low  -> 0비트 시프트
            shift = (self.STATE_CHUNKS - 1 - i) * self.CHUNK_BITS 
            state |= (chunk << shift)
            
        self.decode_state = state
        # --- [수정 완료] ---


    def decode(self, cmf_tables):
        """ (이전과 동일) """
        
        state = self.decode_state
        chunks = self.decode_bitstream
        decoded_indices = []

        # FIFO: CMF 테이블 리스트의 정순으로 디코딩
        for cmf in cmf_tables:
            if cmf[-1] != self.M:
                raise ValueError(f"CMF 테이블이 정규화되지 않았습니다. "
                                 f"cmf[-1] ({cmf[-1]}) != M ({self.M})")
                                 
            # 1. 심볼 찾기 (state % M)
            slot = state & (self.M - 1)

            # 이진 탐색으로 'index'를 찾음: cmf[index] <= slot < cmf[index+1]
            index = bisect.bisect_right(cmf, slot) - 1

            if not (0 <= index < len(cmf) - 1):
                # (디버깅) 만약 여기서 에러가 난다면 state가 잘못 복원된 것입니다.
                raise ValueError(f"디코딩 실패: slot {slot} (state: {state})이 CMF 범위에 없습니다.")

            decoded_indices.append(index)

            c = cmf[index]
            f = cmf[index+1] - c  # f = 빈도수(frequency)

            # 2. 디코딩 (상태 업데이트)
            state = f * (state >> self.precision_bits) + slot - c

            # 3. 정규화 (Renormalization)
            while state < self.LOWER_BOUND and chunks:
                bits = chunks.pop()
                state = (state << self.CHUNK_BITS) | bits
        
        self.decode_state = state
        self.decode_bitstream = chunks

        return decoded_indices


if __name__ == "__main__":
    # 1. 설정
    PRECISION = 10
    M = 1 << PRECISION  # M = 1024
    FILE_NAME = "encoded_data.bin"

    # 2. 인코딩할 데이터 준비
    cmf_0 = [0, 307, 614, 1024]
    cmf_1 = [0, 512, 1024]
    cmf_2 = [0, 102, 307, 922, 1024]

    all_cmf_tables = [cmf_0, cmf_1, cmf_2, cmf_0]
    symbol_indices = [1,      0,     3,     2] # [1, 0, 3, 2]가 나와야 함

    print(f"Original Indices: {symbol_indices}")
    print("-" * 30)

    # 3. 인코딩 및 파일 저장
    encoder = RansEncoderDecoder(precision_bits=PRECISION)
    try:
        encoder.encode(all_cmf_tables, symbol_indices)
        
        # flush()는 이제 bytes를 반환
        binary_bitstream = encoder.flush()
        
        print(f"Encoding successful.")
        print(f"Total bytes written: {len(binary_bitstream)}")

        # 파일에 바이너리 쓰기
        with open(FILE_NAME, "wb") as f:
            f.write(binary_bitstream)
        print(f"File '{FILE_NAME}' saved.")
        print("-" * 30)

        # 4. 파일 읽기 및 디코딩
        decoder = RansEncoderDecoder(precision_bits=PRECISION)
        
        # 파일에서 바이너리 읽기
        print(f"Reading file '{FILE_NAME}'...")
        with open(FILE_NAME, "rb") as f:
            read_bitstream = f.read()

        # (필수) 디코딩 전 set_bitstream(bytes) 호출
        decoder.set_bitstream(read_bitstream)
        
        # CMF 테이블을 순서대로 전달하여 디코딩
        decoded_indices = decoder.decode(all_cmf_tables)

        print(f"Decoding successful.")
        print(f"Decoded Indices:  {decoded_indices}")

        # 5. 검증
        assert symbol_indices == decoded_indices
        print("\nVerification: SUCCESS! (Original == Decoded)")

    except (ValueError, IOError) as e:
        print(f"\nError: {e}")
